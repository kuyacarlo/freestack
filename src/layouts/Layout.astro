---
import "../design-system/global.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "freestack.",
  description = "Free developer tools and student unlocks — hard limits, eligibility, and commercial notes on every row.",
} = Astro.props;

const path = Astro.url.pathname;
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content={description} />
    <meta name="theme-color" content="#0d0c0b" />
    <link rel="preconnect" href="https://fonts.googleapis.com" />
    <link rel="preconnect" href="https://fonts.gstatic.com" crossorigin />
    <link
      href="https://fonts.googleapis.com/css2?family=Inter:opsz,wght@14..32,400;14..32,500;14..32,600;14..32,700&family=JetBrains+Mono:wght@400;500&display=swap"
      rel="stylesheet"
    />
    <link
      rel="icon"
      href="data:image/svg+xml,%3Csvg xmlns='http://www.w3.org/2000/svg' viewBox='0 0 32 32'%3E%3Crect width='32' height='32' rx='5' fill='%230d0c0b'/%3E%3Ctext x='50%25' y='56%25' dominant-baseline='middle' text-anchor='middle' font-size='11' font-family='monospace' fill='%23c4a882'%3Efs%3C/text%3E%3C/svg%3E"
    />
    <title>{title}</title>
  </head>
  <body class="min-h-dvh flex flex-col">
    <nav
      id="nav"
      class="fixed inset-x-0 top-0 z-50 h-[var(--nav-h)] border-b border-transparent transition-[background,border-color] duration-200"
    >
      <div class="ds-wrap flex h-full items-center justify-between">
        <a href="/" class="font-mono text-[0.82rem] font-medium tracking-tight text-ink">
          freestack<em class="not-italic text-ink-3">.</em>
        </a>
        <div class="hidden items-center gap-1.5 sm:flex">
          <a
            href="/"
            class:list={[
              "rounded-md px-2.5 py-1 text-[0.8rem] transition-colors",
              path === "/" ? "text-ink" : "text-ink-2 hover:bg-s1 hover:text-ink",
            ]}>directory</a
          >
          <a
            href="/guides/claim-order"
            class:list={[
              "rounded-md px-2.5 py-1 text-[0.8rem] transition-colors",
              path.startsWith("/guides/claim-order")
                ? "text-ink"
                : "text-ink-2 hover:bg-s1 hover:text-ink",
            ]}>claim order</a
          >
          <a
            href="/guides/stacks"
            class:list={[
              "rounded-md px-2.5 py-1 text-[0.8rem] transition-colors",
              path.startsWith("/guides/stacks")
                ? "text-ink"
                : "text-ink-2 hover:bg-s1 hover:text-ink",
            ]}>stacks</a
          >
          <a
            href="/guides/startup"
            class:list={[
              "rounded-md px-2.5 py-1 text-[0.8rem] transition-colors",
              path.startsWith("/guides/startup")
                ? "text-ink"
                : "text-ink-2 hover:bg-s1 hover:text-ink",
            ]}>startup</a
          >
          <a
            href="/docs"
            class:list={[
              "rounded-md px-2.5 py-1 text-[0.8rem] transition-colors",
              path.startsWith("/docs")
                ? "text-ink"
                : "text-ink-2 hover:bg-s1 hover:text-ink",
            ]}>api</a
          >
          <a
            href="https://github.com/kuyacarlo/awesome-freestack"
            target="_blank"
            rel="noopener noreferrer"
            class="ds-btn ds-btn-outline ml-2 !px-3.5 !py-1 text-[0.8rem]"
            >awesome list ↗</a
          >
        </div>
        <button
          id="nav-toggle"
          type="button"
          class="flex flex-col gap-1 p-1 sm:hidden"
          aria-label="Menu"
        >
          <span class="block h-[1.5px] w-[18px] rounded bg-ink-2"></span>
          <span class="block h-[1.5px] w-[18px] rounded bg-ink-2"></span>
          <span class="block h-[1.5px] w-[18px] rounded bg-ink-2"></span>
        </button>
      </div>
    </nav>

    <div
      id="mobile-nav"
      class="fixed inset-0 z-[90] hidden flex-col items-center justify-center gap-7 bg-bg"
    >
      <button
        id="nav-close"
        type="button"
        class="absolute top-[18px] right-6 text-[1.1rem] text-ink-3"
        aria-label="Close">✕</button
      >
      <a href="/" class="text-2xl font-semibold text-ink-2">directory</a>
      <a href="/guides/claim-order" class="text-2xl font-semibold text-ink-2"
        >claim order</a
      >
      <a href="/guides/stacks" class="text-2xl font-semibold text-ink-2">stacks</a>
      <a href="/guides/startup" class="text-2xl font-semibold text-ink-2">startup</a>
      <a href="/docs" class="text-2xl font-semibold text-ink-2">api</a>
      <a
        href="https://github.com/kuyacarlo/awesome-freestack"
        class="text-2xl font-semibold text-ink-2">awesome list</a
      >
    </div>

    <main class="flex-1 pt-[var(--nav-h)]">
      <slot />
    </main>

    <footer class="border-t border-b1 py-10">
      <div
        class="ds-wrap flex flex-col gap-3 text-[0.8rem] text-ink-3 sm:flex-row sm:items-start sm:justify-between"
      >
        <div class="max-w-lg space-y-2">
          <p>
            Limits drift. Re-check partner pages before you plan a launch on $0.
          </p>
          <p>
            Built with a Cursor subscription from
            <span class="text-ink-2">Stimmie</span> — thanks for funding the tooling that shipped this.
          </p>
        </div>
        <p class="font-mono shrink-0">
          freestack<em class="not-italic">.</em> · not affiliated with any vendor
        </p>
      </div>
    </footer>

    <script>
      const nav = document.getElementById("nav");
      const onScroll = () => {
        if (!nav) return;
        if (window.scrollY > 8) {
          nav.classList.add("border-b1", "bg-[#0d0c0be0]", "backdrop-blur-[14px]");
          nav.classList.remove("border-transparent");
        } else {
          nav.classList.remove("border-b1", "bg-[#0d0c0be0]", "backdrop-blur-[14px]");
          nav.classList.add("border-transparent");
        }
      };
      window.addEventListener("scroll", onScroll, { passive: true });

      const open = document.getElementById("nav-toggle");
      const close = document.getElementById("nav-close");
      const drawer = document.getElementById("mobile-nav");
      open?.addEventListener("click", () => drawer?.classList.replace("hidden", "flex"));
      close?.addEventListener("click", () => drawer?.classList.replace("flex", "hidden"));
    </script>
  </body>
</html>
