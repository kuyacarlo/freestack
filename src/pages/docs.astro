---
import Layout from "../layouts/Layout.astro";
---

<Layout
  title="API docs · freestack."
  description="Interactive OpenAPI reference for freestack claim and tools endpoints."
>
  <section class="border-b border-b1 bg-bg">
    <div class="ds-wrap flex flex-wrap items-end justify-between gap-4 py-8">
      <div>
        <p class="font-mono text-[0.68rem] tracking-wide text-ink-3 uppercase">API</p>
        <h1 class="mt-1 text-2xl font-bold tracking-tight text-ink">freestack API</h1>
        <p class="mt-2 max-w-xl text-[0.92rem] text-ink-2">
          Public JSON. Spec:{" "}
          <a class="text-sand underline-offset-2 hover:underline" href="/api/openapi.json"
            >/api/openapi.json</a
          >
        </p>
      </div>
      <a href="/guides/claim-order" class="ds-btn ds-btn-outline">Claim order →</a>
    </div>
  </section>

  <div id="scalar-root" class="min-h-[75vh] border-t border-b1"></div>
</Layout>

<script
  is:inline
  src="https://cdn.jsdelivr.net/npm/@scalar/api-reference@1.28.11/dist/browser/standalone.js"
></script>
<script is:inline>
  window.Scalar.createApiReference("#scalar-root", {
    url: "/api/openapi.json",
    theme: "deepSpace",
    darkMode: true,
    hideDarkModeToggle: true,
    layout: "modern",
    defaultHttpClient: { targetKey: "shell", clientKey: "curl" },
  });
</script>
