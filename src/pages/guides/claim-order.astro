---
import Layout from "../../layouts/Layout.astro";

const steps = [
  {
    n: "01",
    title: "GitHub Student Developer Pack",
    why: "One verification unlocks Pro, Copilot, Codespaces, and 80+ partner offers.",
    href: "https://education.github.com/pack",
  },
  {
    n: "02",
    title: "JetBrains All Products",
    why: "Daily IDE pack — IntelliJ, PyCharm, WebStorm, Rider, CLion. Renew yearly.",
    href: "https://www.jetbrains.com/community/education/",
  },
  {
    n: "03",
    title: "Azure for Students",
    why: "$100 credit per year, no credit card, renewable while enrolled.",
    href: "https://azure.microsoft.com/en-us/free/students/",
  },
  {
    n: "04",
    title: "Figma Education",
    why: "Professional plan free for higher-ed. Edu-only — keep commercial work elsewhere.",
    href: "https://www.figma.com/education/apply",
  },
  {
    n: "05",
    title: "MATLAB / Autodesk (campus)",
    why: "If your uni has Campus-Wide or Edu licenses, grab them before you buy anything.",
    href: "https://matlab.mathworks.com",
  },
  {
    n: "06",
    title: "Unity Student",
    why: "Pro Editor for verified students 16+. SheerID check.",
    href: "https://unity.com/products/unity-student",
  },
  {
    n: "07",
    title: "Pack cloud credits",
    why: "DigitalOcean, Heroku, MongoDB Atlas — burn on real demos, not idle VMs.",
    href: "https://education.github.com/pack",
  },
  {
    n: "08",
    title: "Domains",
    why: "Namecheap .me / Name.com / .TECH — claim when you have a project name.",
    href: "https://education.github.com/pack",
  },
  {
    n: "09",
    title: "Learning + niche",
    why: "Frontend Masters, Educative, LocalStack, Termius, Doppler Team via Pack.",
    href: "https://education.github.com/pack",
  },
];

/** Directories — not a shout-out list of communities. */
const altPaths = [
  {
    need: "Community seats for data courses",
    where: "Vendor donate / partner networks",
    href: "https://www.datacamp.com/donates",
  },
  {
    need: "PH edtech & campus lists",
    where: "Curated awesome lists",
    href: "https://github.com/smmariquit/awesome-ph-edtech",
  },
  {
    need: "PH student-life tooling list",
    where: "Curated awesome list",
    href: "https://github.com/smmariquit/awesomeph-studentlife",
  },
  {
    need: "Find a campus developer club",
    where: "Chapter directory",
    href: "https://developers.google.com/community/gdsc",
  },
  {
    need: "Corporate free learning tracks",
    where: "CSR learning portals",
    href: "https://skillsbuild.org/",
  },
  {
    need: "More free corp / skilling portals",
    where: "Regional grow programs · docs sandboxes",
    href: "https://grow.google/intl/en_ph/certificates/",
  },
  {
    need: "Certificate financial aid",
    where: "Per-course aid forms",
    href: "https://www.coursera.help/hc/en-us/articles/209819033-Apply-for-Financial-Aid",
  },
  {
    need: "Paid OSS internships (seasonal)",
    where: "Program application hubs",
    href: "https://summerofcode.withgoogle.com/",
  },
  {
    need: "Underrepresented FOSS stipends",
    where: "Internship program hub",
    href: "https://www.outreachy.org/",
  },
  {
    need: "Production OSS fellowship tracks",
    where: "Fellowship applications",
    href: "https://fellowship.mlh.io/",
  },
];
---

<Layout title="claim order · freestack." description="What to claim first as a student.">
  <section class="ds-wrap py-[88px] sm:py-[110px]">
    <div class="ds-section-label">
      <span class="ds-section-num">01</span>
      <span class="ds-section-name">Claim order</span>
      <span class="ds-hairline flex-1"></span>
    </div>

    <h1
      class="mb-5 max-w-3xl text-[clamp(2.2rem,5vw,3.6rem)] leading-[1.05] font-bold tracking-[-0.03em]"
    >
      High-ROI first.<br />
      <span class="text-ink-3">Leave nothing on the table.</span>
    </h1>
    <p class="mb-14 max-w-xl text-ink-2">
      Student status expires. Claim ongoing licenses early, burn time-boxed credits on
      projects that need them, and keep edu-only tools off commercial production.
    </p>
    <p class="mb-14 max-w-xl font-mono text-[0.85rem] text-ink-3">
      Same plan via API / CLI —{" "}
      <a class="text-sand underline-offset-2 hover:underline" href="/docs">API docs</a>
      {" "}·{" "}
      <a class="text-sand underline-offset-2 hover:underline" href="/api/claim?student=1">/api/claim?student=1</a>
      {" "}·{" "}
      <code class="text-ink-2">pnpm dlx @kuyacarlo/freestack claim --student</code>
    </p>

    <ol class="divide-y divide-b1 border-y border-b1">
      {
        steps.map((s) => (
          <li>
            <a
              href={s.href}
              target="_blank"
              rel="noopener noreferrer"
              class="grid gap-2 py-6 transition-colors hover:bg-s1/50 sm:grid-cols-[4rem_1fr_auto] sm:items-baseline sm:gap-6"
            >
              <span class="font-mono text-[0.72rem] text-ink-3">{s.n}</span>
              <div>
                <div class="font-semibold tracking-tight text-ink">{s.title}</div>
                <p class="mt-1 text-[0.95rem] text-ink-2">{s.why}</p>
              </div>
              <span class="font-mono text-[0.72rem] text-ink-3">open ↗</span>
            </a>
          </li>
        ))
      }
    </ol>

    <div id="alt-paths" class="mt-20 scroll-mt-[calc(var(--nav-h)+1rem)]">
      <div class="ds-section-label">
        <span class="ds-section-num">10</span>
        <span class="ds-section-name">More ways in</span>
        <span class="ds-hairline flex-1"></span>
      </div>
      <p class="mb-8 max-w-xl text-ink-2">
        Pack isn’t the only door. Use these <strong class="font-medium text-ink">directories</strong>{" "}
        to find community scholarships, campus clubs, and corporate learning CSR — pick a partner
        that fits you; we don’t pitch individual orgs here.
      </p>
      <ul class="divide-y divide-b1 border-y border-b1">
        {
          altPaths.map((row) => (
            <li>
              <a
                href={row.href}
                target="_blank"
                rel="noopener noreferrer"
                class="grid gap-2 py-5 transition-colors hover:bg-s1/50 sm:grid-cols-[1fr_12rem_auto] sm:items-baseline sm:gap-6"
              >
                <span class="text-[0.95rem] text-ink">{row.need}</span>
                <span class="font-mono text-[0.72rem] text-ink-3">{row.where}</span>
                <span class="font-mono text-[0.72rem] text-ink-3">open ↗</span>
              </a>
            </li>
          ))
        }
      </ul>
      <p class="mt-6 max-w-xl text-[0.85rem] text-ink-3">
        Also worth a pass:{" "}
        <a
          class="text-sand underline-offset-2 hover:underline"
          href="https://learn.microsoft.com/"
          target="_blank"
          rel="noopener noreferrer"
          >docs sandboxes</a
        >
        {" "}·{" "}
        <a
          class="text-sand underline-offset-2 hover:underline"
          href="https://education.github.com/experts"
          target="_blank"
          rel="noopener noreferrer"
          >campus leadership programs</a
        >
        {" "}· directory tab{" "}
        <a class="text-sand underline-offset-2 hover:underline" href="/?hint=ph">PH & campus</a>.
      </p>
    </div>
  </section>
</Layout>
