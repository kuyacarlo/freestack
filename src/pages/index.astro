---
import Layout from "../layouts/Layout.astro";
import Directory from "../components/Directory.astro";
import { tools } from "../data/tools";

const studentCount = tools.filter((t) => t.student === "required").length;
const anyoneCount = tools.filter((t) => t.student === "no").length;
---

<Layout>
  <section class="ds-wrap pb-16 pt-[88px] sm:pt-[120px]">
    <div class="mb-7 flex flex-wrap items-baseline justify-between gap-4">
      <h1
        class="text-[clamp(3.2rem,9vw,7.5rem)] leading-[0.9] font-bold tracking-[-0.045em] text-ink"
      >
        freestack<span class="text-ink-3">.</span>
      </h1>
      <span class="ds-status self-start pt-2">
        <span class="ds-status-dot"></span>
        {tools.length} tools · every row has limits
      </span>
    </div>

    <div class="ds-hairline mb-7 w-full"></div>

    <div class="grid gap-8 sm:grid-cols-[1fr_auto] sm:items-end">
      <p class="max-w-xl text-[clamp(0.9rem,1.5vw,1.05rem)] leading-[1.75] text-ink-2">
        Free developer tools and student unlocks. Each listing states the{" "}
        <strong class="font-medium text-ink">hard limits</strong>, who can claim it, and
        whether commercial use is allowed — for builders tired of “generous free tier”
        without numbers.
      </p>
      <div class="flex flex-wrap gap-2 sm:justify-end">
        <a href="#directory" class="ds-btn ds-btn-filled">Browse directory</a>
        <a href="/guides/claim-order" class="ds-btn ds-btn-outline">Claim order →</a>
      </div>
    </div>

    <dl
      class="mt-12 grid gap-4 border-t border-b1 pt-8 font-mono text-[0.72rem] text-ink-3 sm:grid-cols-3"
    >
      <div>
        <dt class="mb-1">anyone</dt>
        <dd class="text-[1.4rem] font-medium tracking-tight text-ink">{anyoneCount}</dd>
      </div>
      <div>
        <dt class="mb-1">student required</dt>
        <dd class="text-[1.4rem] font-medium tracking-tight text-ink">{studentCount}</dd>
      </div>
      <div>
        <dt class="mb-1">source</dt>
        <dd class="text-[0.85rem] leading-relaxed text-ink-2 normal-case">
          Deck notes + pack matrices · offers rotate
        </dd>
      </div>
    </dl>
  </section>

  <Directory />
</Layout>
